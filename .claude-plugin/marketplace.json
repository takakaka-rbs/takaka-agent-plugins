{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "name": "takaka-agent-plugins",
  "owner": {
    "name": "takaka",
    "url": "https://github.com/takaka/takaka-agent-plugins"
  },
  "metadata": {
    "description": "takaka-agent-plugins エコシステムの公式プラグインレジストリ。Claude Code (Agent SDK) 向けプラグインを一元管理する。",
    "version": "0.5.0"
  },
  "plugins": [
    {
      "name": "orchestrator",
      "source": "./plugins/orchestrator",
      "description": "SessionStart フックでルーティング表をコンテキスト注入し、メイン会話をオーケストレーターとして適切なプラグインへの振り分けと複数プラグインの協調実行を担わせるコアプラグイン。",
      "version": "0.2.0",
      "author": {
        "name": "takaka",
        "url": "https://github.com/takaka/takaka-agent-plugins"
      },
      "homepage": "https://github.com/takaka/takaka-agent-plugins/tree/main/plugins/orchestrator",
      "license": "MIT",
      "category": "orchestration"
    },
    {
      "name": "openapi-specificater",
      "source": "./plugins/openapi-specificater",
      "description": "要件定義書（REQ-F-XXX）を参照しながら、APIの機能仕様書として通用するレベルまで記述したOpenAPI仕様書（OpenSpec.yml）を対話形式で作成・更新するプラグイン。",
      "version": "0.1.0",
      "author": {
        "name": "takaka",
        "url": "https://github.com/takaka/takaka-agent-plugins"
      },
      "homepage": "https://github.com/takaka/takaka-agent-plugins/tree/main/plugins/openapi-specificater",
      "license": "MIT",
      "category": "documentation"
    },
    {
      "name": "requirements-specificater",
      "source": "./plugins/requirements-specificater",
      "description": "ユーザーとの対話・コードベース調査・Web調査を通じて、要件定義書テンプレートに沿った要件定義書を作成・更新するプラグイン。",
      "version": "0.1.0",
      "author": {
        "name": "takaka",
        "url": "https://github.com/takaka/takaka-agent-plugins"
      },
      "homepage": "https://github.com/takaka/takaka-agent-plugins/tree/main/plugins/requirements-specificater",
      "license": "MIT",
      "category": "documentation"
    },
    {
      "name": "screen-specificater",
      "source": "./plugins/screen-specificater",
      "description": "要件定義書（REQ-F-XXX）とOpenAPI仕様書（API-XXX）を参照しながら、コンポーネント配置・イベントハンドラー・表示制御まで記述した画面仕様書（Markdown）を対話形式で作成・更新するプラグイン。",
      "version": "0.1.0",
      "author": {
        "name": "takaka",
        "url": "https://github.com/takaka/takaka-agent-plugins"
      },
      "homepage": "https://github.com/takaka/takaka-agent-plugins/tree/main/plugins/screen-specificater",
      "license": "MIT",
      "category": "documentation"
    },
    {
      "name": "github-issue-creator",
      "source": "./plugins/github-issue-creator",
      "description": "ユーザーの指示からGitHub Issueを対話形式で作成するプラグイン。GitHub MCPを優先し、MCPが対応しない操作はgh CLIで補完する。複数Issueの一括作成に対応。",
      "version": "0.1.0",
      "author": {
        "name": "takaka",
        "url": "https://github.com/takaka/takaka-agent-plugins"
      },
      "homepage": "https://github.com/takaka/takaka-agent-plugins/tree/main/plugins/github-issue-creator",
      "license": "MIT",
      "category": "automation"
    },
    {
      "name": "git-commit-pusher",
      "source": "./plugins/git-commit-pusher",
      "description": "現在の変更を内容ごとに分割し、リポジトリのcommitlint設定に沿ったConventional Commitメッセージ（英語）でコミットしてプッシュするプラグイン。前提ツール（git / gh CLI）のチェックを最初に行う。",
      "version": "0.1.0",
      "author": {
        "name": "takaka",
        "url": "https://github.com/takaka/takaka-agent-plugins"
      },
      "homepage": "https://github.com/takaka/takaka-agent-plugins/tree/main/plugins/git-commit-pusher",
      "license": "MIT",
      "category": "automation"
    },
    {
      "name": "plugin-improver",
      "source": "./plugins/plugin-improver",
      "description": "セッション中に検出したスキル/エージェント定義と実作業のズレをフィードバックとして自動記録し、/self-improve スキルで定義本体（SKILL.md / agents/*.md）へ反映する自己改善プラグイン。",
      "version": "0.1.1",
      "author": {
        "name": "takaka",
        "url": "https://github.com/takaka/takaka-agent-plugins"
      },
      "homepage": "https://github.com/takaka/takaka-agent-plugins/tree/main/plugins/plugin-improver",
      "license": "MIT",
      "category": "automation"
    }
  ]
}
